@model List<LaptopStore.Models.Product>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý sản phẩm";
}
<div class="container mt-4">
    <p>
        <a asp-action="Create" class="btn btn-primary">Thêm sản phẩm</a>
    </p>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Tên</th>
                <th>Ảnh</th>
                <th>Giá</th>
                <th>Hãng</th>
                <th>Danh mục</th>
                <th>Tồn kho</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td><img src="~/@item.ImageUrl" width="80" /></td>
                    <td>@item.Price.ToString("N0") đ</td>
                    <td>@item.Brand?.Name</td>
                    <td>@item.Category?.Name</td>
                    <td>@item.StockQuantity</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-sm btn-warning">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.ProductId" class="btn btn-sm btn-danger">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>