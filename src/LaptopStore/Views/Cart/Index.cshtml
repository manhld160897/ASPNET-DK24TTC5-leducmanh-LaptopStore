@model List<LaptopStore.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng";
    decimal subtotal = 0;
}

<div class="container-fluid pt-5">
    <div class="row px-xl-5">
        <div class="col-lg-8 table-responsive mb-5">
            <table class="table table-bordered mb-0">
                <thead class="bg-secondary text-dark">
                    <tr>
                        <th class="text-center">Sản phẩm</th>
                        <th class="text-center">Giá</th>
                        <th class="text-center">Số lượng</th>
                        <th class="text-center">Thành tiền</th>
                        <th class="text-center">Xóa</th>
                    </tr>
                </thead>
                <tbody class="align-middle">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            var total = item.Product.Price * item.Quantity;
                            subtotal += total;

                            <tr>
                                <td class="align-middle">
                                    <img src="~/@(item.Product.ImageUrl ?? "img/no-image.png")" alt="" width="50">
                                    @item.Product.Name
                                </td>
                                <td class="align-middle text-center">@item.Product.Price.ToString("N0") đ</td>
                                <td class="align-middle text-center">
                                    <div class="input-group quantity mx-auto" style="width: 120px;">
                                        <div class="input-group-btn">
                                            <a asp-controller="Cart" asp-action="Decrease" asp-route-id="@item.CartItemId"
                                               class="btn btn-sm btn-primary">
                                                <i class="fa fa-minus"></i>
                                            </a>
                                        </div>
                                        <input type="text" class="form-control form-control-sm bg-secondary text-center" value="@item.Quantity" readonly>
                                        <div class="input-group-btn">
                                            <a asp-controller="Cart" asp-action="Increase" asp-route-id="@item.CartItemId"
                                               class="btn btn-sm btn-primary">
                                                <i class="fa fa-plus"></i>
                                            </a>
                                        </div>
                                    </div>
                                </td>
                                <td class="align-middle text-center">@total.ToString("N0") đ</td>
                                <td class="align-middle text-center">
                                    <a asp-controller="Cart" asp-action="Remove" asp-route-id="@item.CartItemId"
                                       class="btn btn-sm btn-primary">
                                        <i class="fa fa-times"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center">Giỏ hàng đang trống.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="col-lg-4">
            <div class="card border-secondary mb-5">
                <div class="card-header bg-secondary border-0">
                    <h4 class="m-0">Tóm tắt giỏ hàng</h4>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-3 pt-1">
                        <h6>Tạm tính</h6>
                        <h6>@subtotal.ToString("N0") đ</h6>
                    </div>
                    <div class="d-flex justify-content-between">
                        <h6>Phí ship</h6>
                        <h6>0 đ</h6>
                    </div>
                </div>
                <div class="card-footer border-secondary bg-transparent">
                    <div class="d-flex justify-content-between mt-2">
                        <h5>Tổng cộng</h5>
                        <h5>@subtotal.ToString("N0") đ</h5>
                    </div>
                    <a asp-controller="Order" asp-action="Checkout" class="btn btn-block btn-primary my-3 py-3">
                        Thanh toán
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>