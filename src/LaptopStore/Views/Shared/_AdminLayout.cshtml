<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Admin LaptopStore</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link href="~/img/favicon.ico" rel="icon" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="~/css/style.css" rel="stylesheet">
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-2 bg-dark min-vh-100 p-0">
                <div class="p-4 text-white">
                    <h4 class="text-white mb-4">ADMIN</h4>

                    <div class="nav flex-column nav-pills">
                        <a asp-controller="Admin" asp-action="Index" class="nav-link text-white mb-2">
                            <i class="fas fa-home mr-2"></i>Trang quản trị
                        </a>
                        <a asp-controller="AdminProduct" asp-action="Index" class="nav-link text-white mb-2">
                            <i class="fas fa-laptop mr-2"></i>Sản phẩm
                        </a>
                        <a asp-controller="AdminOrder" asp-action="Index" class="nav-link text-white mb-2">
                            <i class="fas fa-shopping-bag mr-2"></i>Đơn hàng
                        </a>
                        <a asp-controller="AdminCustomer" asp-action="Index" class="nav-link text-white mb-2">
                            <i class="fas fa-users mr-2"></i>Khách hàng
                        </a>
                        <a asp-controller="Home" asp-action="Index" class="nav-link text-white mb-2">
                            <i class="fas fa-globe mr-2"></i>Về trang chủ
                        </a>
                        <a asp-controller="Account" asp-action="Logout" class="nav-link text-white">
                            <i class="fas fa-sign-out-alt mr-2"></i>Đăng xuất
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-lg-10 p-0">
                <div class="bg-light border-bottom px-4 py-3 d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">@ViewData["Title"]</h4>
                    <span>Xin chào, @Context.Session.GetString("CustomerName")</span>
                </div>

                <div class="p-4">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>