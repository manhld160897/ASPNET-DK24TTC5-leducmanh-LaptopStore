@using Microsoft.AspNetCore.Http
@using System.Linq
@inject LaptopStore.Repository.DataContext _context

@{
    int cartCount = 0;
    int wishlistCount = 0;
    var customerId = Context.Session.GetInt32("CustomerId");

    if (customerId != null)
    {
        cartCount = _context.CartItems.Count(c => c.CustomerId == customerId.Value);
        wishlistCount = _context.WishlistItems.Count(w => w.CustomerId == customerId.Value);
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - LaptopStore</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <meta content="Laptop Store" name="keywords" />
    <meta content="Website bán laptop" name="description" />

    <link href="~/img/favicon.ico" rel="icon" />

    <link rel="preconnect" href="https://fonts.gstatic.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="~/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">
    <link href="~/css/style.css" rel="stylesheet">
</head>

<body>

    <!-- Topbar Start -->
    <div class="container-fluid">
        <div class="row bg-secondary py-2 px-xl-5">
            <div class="col-lg-6 d-none d-lg-block">
                <div class="d-inline-flex align-items-center">
                    <a class="text-dark" href="">Giới thiệu</a>
                    <span class="text-muted px-2">|</span>
                    <a class="text-dark" href="">Hỗ trợ</a>
                    <span class="text-muted px-2">|</span>
                    <a class="text-dark" href="">Liên hệ</a>
                </div>
            </div>
            <div class="col-lg-6 text-center text-lg-right">
                <div class="d-inline-flex align-items-center">
                    <a class="text-dark px-2" href="#"><i class="fab fa-facebook-f"></i></a>
                    <a class="text-dark px-2" href="#"><i class="fab fa-twitter"></i></a>
                    <a class="text-dark px-2" href="#"><i class="fab fa-instagram"></i></a>
                </div>
            </div>
        </div>

        <div class="row align-items-center py-3 px-xl-5">
            <div class="col-lg-3 d-none d-lg-block">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                    <h1 class="m-0 display-5 font-weight-semi-bold">
                        <span class="text-primary font-weight-bold  px-3 mr-1">LAPTOPSTORE</span>
                    </h1>
                </a>
            </div>
            <div class="col-lg-6 col-6 text-left">
                <form asp-controller="Home" asp-action="Index" method="get">
                    <div class="input-group">
                        <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control" placeholder="Tìm kiếm laptop">
                        <div class="input-group-append">
                            <button type="submit" class="input-group-text bg-transparent text-primary border-0">
                                <i class="fa fa-search"></i>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
            <div class="col-lg-3 col-6 text-right">
                <a asp-controller="Wishlist" asp-action="Index" class="btn border">
                    <i class="fas fa-heart text-primary"></i>
                    <span class="badge">@wishlistCount</span>
                </a>
                <a asp-controller="Cart" asp-action="Index" class="btn border">
                    <i class="fas fa-shopping-cart text-primary"></i>
                    <span class="badge">@cartCount</span>
                </a>
            </div>
        </div>
    </div>
    <!-- Topbar End -->
    <!-- Navbar Start -->
    <div class="container-fluid mb-5">
        <div class="row border-top px-xl-5">
            <div class="col-lg-3 d-none d-lg-block">
                <a class="btn shadow-none d-flex align-items-center justify-content-between bg-primary text-white w-100"
                   data-toggle="collapse" href="#navbar-vertical"
                   style="height: 65px; margin-top: -1px; padding: 0 30px;">
                    <h6 class="m-0">Danh mục</h6>
                    <i class="fa fa-angle-down text-dark"></i>
                </a>
                <nav class="collapse show navbar navbar-vertical navbar-light align-items-start p-0 border border-top-0 border-bottom-0"
                     id="navbar-vertical">
                    @await Component.InvokeAsync("CategoryMenu")
                </nav>
            </div>

            <div class="col-lg-9">
                <nav class="navbar navbar-expand-lg bg-light navbar-light py-3 py-lg-0 px-0">
                    <a asp-controller="Home" asp-action="Index" class="text-decoration-none d-block d-lg-none">
                        <h1 class="m-0 display-5 font-weight-semi-bold">
                            <span class="text-primary font-weight-bold border px-3 mr-1">L</span>LaptopStore
                        </h1>
                    </a>

                    <button type="button" class="navbar-toggler" data-toggle="collapse" data-target="#navbarCollapse">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse justify-content-between" id="navbarCollapse">
                        <div class="navbar-nav mr-auto py-0">
                            <a asp-controller="Home" asp-action="Index" class="nav-item nav-link active">Trang chủ</a>
                            <a asp-controller="Home" asp-action="Index" class="nav-item nav-link">Sản phẩm</a>
                            <a href="#" class="nav-item nav-link">Giới thiệu</a>
                            <a href="#" class="nav-item nav-link">Liên hệ</a>
                        </div>
                        <div class="navbar-nav ml-auto py-0">
                            @if (Context.Session.GetString("CustomerName") == null)
                            {

                                <a asp-controller="Account" asp-action="Login" class="nav-item nav-link">Đăng nhập</a>
                                <a asp-controller="Account" asp-action="Register" class="nav-item nav-link">Đăng ký</a>
                            }
                            else
                            {
                                @if (Context.Session.GetString("Role") == "Admin")
                                {
                                    <a asp-controller="Admin" asp-action="Index" class="nav-item nav-link">Quản trị</a>
                                }
                                <span class="nav-item nav-link">Xin chào, @Context.Session.GetString("CustomerName")</span>
                                <a asp-controller="Order" asp-action="MyOrders" class="nav-item nav-link">Đơn hàng</a>
                                <a asp-controller="Account" asp-action="Logout" class="nav-item nav-link">Đăng xuất</a>
                            }
                        </div>
                    </div>
                </nav>

                @RenderBody()
            </div>
        </div>
    </div>
    <!-- Navbar End -->
    <div class="container-fluid bg-secondary text-dark mt-5 pt-5">
        <div class="row px-xl-5 pt-4 pb-3">
            <div class="col-lg-4 col-md-6 mb-4">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                    <h3 class="mb-3 font-weight-bold text-dark">LAPTOPSTORE</h3>
                </a>
                <p class="mb-2">
                    Website bán laptop dành cho học tập, văn phòng, gaming và đồ họa.
                </p>
                <p class="mb-2">
                    <i class="fa fa-map-marker-alt text-primary mr-2"></i>273 An Dương Vương, Quận 5, TP. Hồ Chí Minh
                </p>
                <p class="mb-2">
                    <i class="fa fa-envelope text-primary mr-2"></i>laptopstore@gmail.com
                </p>
                <p class="mb-0">
                    <i class="fa fa-phone-alt text-primary mr-2"></i>0123 456 789
                </p>
            </div>

            <div class="col-lg-4 col-md-6 mb-4">
                <h5 class="font-weight-bold text-dark mb-3">Liên kết nhanh</h5>
                <div class="d-flex flex-column">
                    <a class="text-dark mb-2" asp-controller="Home" asp-action="Index">
                        <i class="fa fa-angle-right mr-2"></i>Trang chủ
                    </a>
                    <a class="text-dark mb-2" asp-controller="Home" asp-action="Index">
                        <i class="fa fa-angle-right mr-2"></i>Sản phẩm
                    </a>
                    <a class="text-dark mb-2" asp-controller="Cart" asp-action="Index">
                        <i class="fa fa-angle-right mr-2"></i>Giỏ hàng
                    </a>
                    <a class="text-dark mb-2" asp-controller="Order" asp-action="MyOrders">
                        <i class="fa fa-angle-right mr-2"></i>Đơn hàng
                    </a>
                    <a class="text-dark" asp-controller="Wishlist" asp-action="Index">
                        <i class="fa fa-angle-right mr-2"></i>Yêu thích
                    </a>
                </div>
            </div>

            <div class="col-lg-4 col-md-12 mb-4">
                <h5 class="font-weight-bold text-dark mb-3">Hỗ trợ</h5>
                <p class="mb-2">Hỗ trợ mua hàng và giải đáp thông tin sản phẩm nhanh chóng.</p>
                <a href="#" class="btn btn-primary px-4">Liên hệ ngay</a>
            </div>
        </div>
    </div>

        <div class="row border-top border-light mx-xl-5 py-4">
            <div class="col-md-6 px-xl-0">
                <p class="mb-md-0 text-center text-md-left text-dark">
                    &copy; <a class="text-dark font-weight-semi-bold" asp-controller="Home" asp-action="Index">LaptopStore</a>.
                    Bản quyền thuộc về LaptopStore. Thiết kế phục vụ đồ án ASP.NET Core MVC.
                </p>
            </div>
            <div class="col-md-6 px-xl-0 text-center text-md-right">
                <img class="img-fluid" src="~/img/payments.png" alt="Phương thức thanh toán">
            </div>
        </div>
    </div>

    <a href="#" class="btn btn-primary back-to-top"><i class="fa fa-angle-double-up"></i></a>

    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/easing/easing.min.js"></script>
    <script src="~/lib/owlcarousel/owl.carousel.min.js"></script>
    <script src="~/mail/jqBootstrapValidation.min.js"></script>
    <script src="~/mail/contact.js"></script>
    <script src="~/js/main.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>