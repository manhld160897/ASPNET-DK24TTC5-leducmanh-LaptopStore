@model List<LaptopStore.Models.Product>
@{
    var wishlistProductIds = ViewBag.WishlistProductIds as List<int> ?? new List<int>();
}
<div class="container-fluid pt-5">
    <div class="row px-xl-5">
        <div class="col-lg-12 col-md-12">
            <div class="row pb-3">


                @if (Model != null && Model.Any())
                {
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var item = Model[i];
                        var isInWishlist = wishlistProductIds.Contains(item.ProductId);

                        <div class="col-lg-4 col-md-6 col-sm-12 pb-1">
                            <div class="card product-item border-0 mb-4">
                                <div class="card-header product-img bg-transparent border p-0 d-flex align-items-center justify-content-center"
                                     style="height:300px; overflow:hidden; position:relative;">

                                    <form asp-controller="Wishlist" asp-action="Toggle" method="post"
                                          style="position:absolute; top:10px; right:10px; z-index:10;">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <button type="submit"
                                                class="btn border-0 bg-white rounded-circle"
                                                style="width:40px; height:40px; box-shadow:0 2px 6px rgba(0,0,0,0.15);">
                                            <i class="fas fa-heart @(isInWishlist ? "text-danger" : "text-secondary")"></i>
                                        </button>
                                    </form>

                                    <img src="~/@(item.ImageUrl ?? "img/no-image.png")"
                                         alt="@item.Name"
                                         style="max-height:100%; max-width:100%; object-fit:contain;">
                                </div>

                                <div class="card-body border-left border-right text-center p-0 pt-4 pb-3">
                                    <h6 class="text-truncate mb-3">@item.Name</h6>
                                    <div class="d-flex justify-content-center">
                                        <h6>@item.Price.ToString("N0") đ</h6>
                                    </div>
                                </div>

                                <div class="card-footer d-flex justify-content-between bg-light border">
                                    <a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId" class="btn btn-sm text-dark p-0">
                                        <i class="fas fa-eye text-primary mr-1"></i>Chi tiết
                                    </a>

                                    <form asp-controller="Cart" asp-action="AddToCart" method="post" style="display:inline;">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <input type="hidden" name="quantity" value="1" />
                                        <button type="submit" class="btn btn-sm text-dark p-0 border-0 bg-transparent">
                                            <i class="fas fa-shopping-cart text-primary mr-1"></i>Thêm vào giỏ hàng
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <p>Chưa có sản phẩm nào.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="row px-xl-5 mt-2">
        <div class="col-12">
            @if (ViewBag.TotalPage > 1)
            {
                <nav>
                    <ul class="pagination justify-content-center mb-3">
                        <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link"
                               asp-controller="Home"
                               asp-action="Index"
                               asp-route-page="@(ViewBag.CurrentPage - 1)"
                               asp-route-categoryId="@ViewBag.CategoryId"
                               asp-route-keyword="@ViewBag.Keyword">
                                &laquo;
                            </a>
                        </li>

                        @for (int i = 1; i <= ViewBag.TotalPage; i++)
                        {
                            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                <a class="page-link"
                                   asp-controller="Home"
                                   asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-categoryId="@ViewBag.CategoryId"
                                   asp-route-keyword="@ViewBag.Keyword">
                                    @i
                                </a>
                            </li>
                        }

                        <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPage ? "disabled" : "")">
                            <a class="page-link"
                               asp-controller="Home"
                               asp-action="Index"
                               asp-route-page="@(ViewBag.CurrentPage + 1)"
                               asp-route-categoryId="@ViewBag.CategoryId"
                               asp-route-keyword="@ViewBag.Keyword">
                                &raquo;
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>