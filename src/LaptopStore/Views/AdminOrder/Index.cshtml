@model List<LaptopStore.Models.Order>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="container-fluid pt-4">
    <div class="row px-xl-5">
        <div class="col-12">
            <div class="mb-4">
                <p class="text-muted mb-0">Danh sách tất cả đơn hàng trong hệ thống.</p>
            </div>
        </div>
    </div>

    <div class="row px-xl-5">
        <div class="col-12">
            <div class="card border-secondary mb-5">
                <div class="card-header bg-secondary text-dark">
                    <h5 class="mb-0">Danh sách đơn hàng</h5>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-bordered text-center mb-0">
                            <thead class="bg-light text-dark">
                                <tr>
                                    <th>Mã đơn</th>
                                    <th>Khách hàng</th>
                                    <th>Ngày đặt</th>
                                    <th>Tổng tiền</th>
                                    <th>Trạng thái hiện tại</th>
                                    <th style="min-width: 260px;">Cập nhật trạng thái</th>
                                    <th>Xem</th>
                                </tr>
                            </thead>
                            <tbody class="align-middle">
                                @if (Model != null && Model.Any())
                                {
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td><strong>#@item.OrderId</strong></td>
                                            <td>@item.Customer?.FullName</td>
                                            <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="text-primary font-weight-bold">@item.TotalAmount.ToString("N0") đ</td>

                                            <td>
                                                @if (item.Status == "Pending")
                                                {
                                                    <span class="badge badge-warning">Chờ xác nhận</span>
                                                }
                                                else if (item.Status == "Confirmed")
                                                {
                                                    <span class="badge badge-info">Đã xác nhận</span>
                                                }
                                                else if (item.Status == "Shipping")
                                                {
                                                    <span class="badge badge-primary">Đang giao hàng</span>
                                                }
                                                else if (item.Status == "Completed")
                                                {
                                                    <span class="badge badge-success">Hoàn thành</span>
                                                }
                                                else if (item.Status == "Cancelled")
                                                {
                                                    <span class="badge badge-danger">Đã hủy</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-secondary">@item.Status</span>
                                                }
                                            </td>

                                            <td>
                                                <form asp-action="UpdateStatus" method="post" class="d-flex justify-content-center align-items-center">
                                                    <input type="hidden" name="orderId" value="@item.OrderId" />

                                                    <select name="status" class="form-control form-control-sm mr-2">
                                                        <option value="Pending" selected="@(item.Status == "Pending")">Chờ xác nhận</option>
                                                        <option value="Confirmed" selected="@(item.Status == "Confirmed")">Đã xác nhận</option>
                                                        <option value="Shipping" selected="@(item.Status == "Shipping")">Đang giao hàng</option>
                                                        <option value="Completed" selected="@(item.Status == "Completed")">Hoàn thành</option>
                                                        <option value="Cancelled" selected="@(item.Status == "Cancelled")">Đã hủy</option>
                                                    </select>

                                                    <button type="submit" class="btn btn-sm btn-primary">
                                                        Cập nhật
                                                    </button>
                                                </form>
                                            </td>

                                            <td>
                                                <a asp-action="Details" asp-route-id="@item.OrderId" class="btn btn-sm btn-info">
                                                    Chi tiết
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center py-4">
                                            Chưa có đơn hàng nào.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                @if (Model != null && Model.Any())
                {
                    <div class="card-footer bg-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted">Tổng số đơn hàng: <strong>@Model.Count</strong></span>
                            <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary">
                                Quay lại quản trị
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>