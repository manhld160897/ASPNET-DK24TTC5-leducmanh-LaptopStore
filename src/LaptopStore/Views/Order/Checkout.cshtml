@model LaptopStore.Models.CheckoutViewModel

@{
    ViewData["Title"] = "Thanh toán";
}

<div class="container-fluid pt-5">
    <div class="row px-xl-5">
        <div class="col-lg-8 mx-auto">
            <div class="card border-secondary">
                <div class="card-header bg-secondary border-0">
                    <h4 class="m-0">Thông tin đặt hàng</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Checkout" method="post">
                        <div class="form-group mb-3">
                            <label>Họ tên người nhận</label>
                            <input asp-for="ReceiverName" class="form-control" />
                            <span asp-validation-for="ReceiverName" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label>Số điện thoại</label>
                            <input asp-for="ReceiverPhone" class="form-control" />
                            <span asp-validation-for="ReceiverPhone" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label>Địa chỉ giao hàng</label>
                            <textarea asp-for="ShippingAddress" class="form-control"></textarea>
                            <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary">Đặt hàng</button>
                        <a asp-controller="Cart" asp-action="Index" class="btn btn-secondary">Quay lại giỏ hàng</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}