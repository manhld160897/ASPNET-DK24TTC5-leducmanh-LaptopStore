@model LaptopStore.Models.Order

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="container-fluid pt-5">
    <div class="row px-xl-5">
        <div class="col-12 mb-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap">
                <div>
                    <h2 class="font-weight-bold mb-2">Chi tiết đơn hàng</h2>
                    <p class="text-muted mb-0">Mã đơn hàng: <strong>#@Model.OrderId</strong></p>
                </div>
                <a asp-action="MyOrders" class="btn btn-outline-primary mt-2 mt-md-0">
                    Quay lại đơn hàng
                </a>
            </div>
        </div>
    </div>

    <div class="row px-xl-5">
        <div class="col-lg-6 mb-4">
            <div class="card border-secondary h-100">
                <div class="card-header bg-secondary text-dark">
                    <h5 class="mb-0">Thông tin đơn hàng</h5>
                </div>
                <div class="card-body">
                    <p><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                    <p>
                        <strong>Trạng thái:</strong>
                        @if (Model.Status == "Pending")
                        {
                            <span class="badge badge-warning">Chờ xác nhận</span>
                        }
                        else if (Model.Status == "Confirmed")
                        {
                            <span class="badge badge-info">Đã xác nhận</span>
                        }
                        else if (Model.Status == "Shipping")
                        {
                            <span class="badge badge-primary">Đang giao hàng</span>
                        }
                        else if (Model.Status == "Completed")
                        {
                            <span class="badge badge-success">Hoàn thành</span>
                        }
                        else if (Model.Status == "Cancelled")
                        {
                            <span class="badge badge-danger">Đã hủy</span>
                        }
                        else
                        {
                            <span class="badge badge-secondary">@Model.Status</span>
                        }
                    </p>
                    <p class="mb-0">
                        <strong>Tổng tiền:</strong>
                        <span class="text-primary font-weight-bold">@Model.TotalAmount.ToString("N0") đ</span>
                    </p>
                </div>
            </div>
        </div>

        <div class="col-lg-6 mb-4">
            <div class="card border-secondary h-100">
                <div class="card-header bg-secondary text-dark">
                    <h5 class="mb-0">Thông tin nhận hàng</h5>
                </div>
                <div class="card-body">
                    <p><strong>Người nhận:</strong> @Model.ReceiverName</p>
                    <p><strong>Số điện thoại:</strong> @Model.ReceiverPhone</p>
                    <p class="mb-0"><strong>Địa chỉ giao hàng:</strong> @Model.ShippingAddress</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row px-xl-5">
        <div class="col-12">
            <div class="card border-secondary mb-5">
                <div class="card-header bg-secondary text-dark">
                    <h5 class="mb-0">Sản phẩm trong đơn hàng</h5>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-bordered text-center mb-0">
                            <thead class="bg-light text-dark">
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th>Hình ảnh</th>
                                    <th>Đơn giá</th>
                                    <th>Số lượng</th>
                                    <th>Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody class="align-middle">
                                @if (Model.OrderDetails != null && Model.OrderDetails.Any())
                                {
                                    @foreach (var item in Model.OrderDetails)
                                    {
                                        <tr>
                                            <td class="align-middle">@item.Product?.Name</td>
                                            <td class="align-middle">
                                                <img src="~/@(item.Product?.ImageUrl ?? "img/no-image.png")"
                                                     alt="@item.Product?.Name"
                                                     width="80" />
                                            </td>
                                            <td class="align-middle">@item.UnitPrice.ToString("N0") đ</td>
                                            <td class="align-middle">@item.Quantity</td>
                                            <td class="align-middle text-primary font-weight-bold">
                                                @item.SubTotal.ToString("N0") đ
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5">Không có sản phẩm trong đơn hàng.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="card-footer bg-white">
                    <div class="d-flex justify-content-end">
                        <h4 class="mb-0">
                            Tổng thanh toán:
                            <span class="text-primary">@Model.TotalAmount.ToString("N0") đ</span>
                        </h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>