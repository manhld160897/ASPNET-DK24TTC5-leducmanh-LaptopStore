@model List<LaptopStore.Models.Order>

@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<div class="container-fluid pt-5">
    <div class="row px-xl-5">
        <div class="col-12 mb-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap">
                <div>
                    <h2 class="font-weight-bold mb-2">Đơn hàng của tôi</h2>
                    <p class="text-muted mb-0">Theo dõi các đơn hàng bạn đã đặt tại LaptopStore.</p>
                </div>
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary mt-2 mt-md-0">
                    Tiếp tục mua hàng
                </a>
            </div>
        </div>
    </div>

    <div class="row px-xl-5">
        <div class="col-12">
            <div class="card border-secondary mb-5">
                <div class="card-header bg-secondary text-dark">
                    <h5 class="mb-0">Danh sách đơn hàng</h5>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-bordered text-center mb-0">
                            <thead class="bg-light text-dark">
                                <tr>
                                    <th>Mã đơn</th>
                                    <th>Ngày đặt</th>
                                    <th>Tổng tiền</th>
                                    <th>Trạng thái</th>
                                    <th>Xem chi tiết</th>
                                </tr>
                            </thead>
                            <tbody class="align-middle">
                                @if (Model != null && Model.Any())
                                {
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="align-middle">
                                                <strong>#@item.OrderId</strong>
                                            </td>
                                            <td class="align-middle">
                                                @item.OrderDate.ToString("dd/MM/yyyy HH:mm")
                                            </td>
                                            <td class="align-middle text-primary font-weight-bold">
                                                @item.TotalAmount.ToString("N0") đ
                                            </td>
                                            <td class="align-middle">
                                                @if (item.Status == "Pending")
                                                {
                                                    <span class="badge badge-warning">Chờ xác nhận</span>
                                                }
                                                else if (item.Status == "Confirmed")
                                                {
                                                    <span class="badge badge-info">Đã xác nhận</span>
                                                }
                                                else if (item.Status == "Shipping")
                                                {
                                                    <span class="badge badge-primary">Đang giao hàng</span>
                                                }
                                                else if (item.Status == "Completed")
                                                {
                                                    <span class="badge badge-success">Hoàn thành</span>
                                                }
                                                else if (item.Status == "Cancelled")
                                                {
                                                    <span class="badge badge-danger">Đã hủy</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-secondary">@item.Status</span>
                                                }
                                            </td>
                                            <td class="align-middle">
                                                <a asp-action="Details" asp-route-id="@item.OrderId" class="btn btn-sm btn-primary">
                                                    Chi tiết
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-4">
                                            Bạn chưa có đơn hàng nào.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                @if (Model != null && Model.Any())
                {
                    <div class="card-footer bg-white">
                        <div class="d-flex justify-content-between align-items-center flex-wrap">
                            <span class="text-muted">
                                Tổng số đơn hàng: <strong>@Model.Count</strong>
                            </span>
                            <span class="text-muted mt-2 mt-md-0">
                                Cảm ơn bạn đã mua sắm tại LaptopStore
                            </span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>